-- data.trz â€” Capa de datos del CronometroPSP
-- Solo estructura. Cero comportamiento.
-- Convertido de data.trz (6 marzo 2026) a .trz (12 marzo 2026)

-- Dominio principal

data TipoTarea:
    tipoId: Id
    nombre: Texto
    icono: Texto
    mutable usos7d: Entero
    mutable actividades_permitidas: Lista<Id>

data Tarea:
    tareaId: Id           -- compuesto: "{tipoId}_{actividadId}"
    tipoId: Id
    actividadId: Id
    nombre: Texto
    icono: Texto

data Actividad:
    id: Id
    nombre: Texto
    color: Color
    permanente: Booleano

data Sesion:
    sesionId: Id
    tareaId: Id
    inicio: Timestamp
    notas: Texto?          -- opcional: puede no haber comentario

-- Datos de UI (elementos interactivos como roles)

data CampoTexto:
    id: Id
    valor: Texto
    valido: Booleano

data CampoNumerico:
    id: Id
    valor: Entero
    minimo: Entero

data Boton:
    id: Id
    etiqueta: Texto
    mutable habilitado: Booleano

data Checkbox:
    id: Id
    etiqueta: Texto
    mutable marcado: Booleano

data SelectorColor:
    id: Id
    opciones: Lista<Color>
    mutable seleccionado: Color

data SelectorIcono:
    id: Id
    iconos: Lista<Texto>
    mutable seleccionado: Texto
    mutable filtro: Texto

data PestaÃ±a:
    id: Id
    etiqueta: Texto

data ItemMenu:
    id: Id
    etiqueta: Texto

-- Datos del historial

data DiaHistorial:
    timestamp: Timestamp
    total: Entero           -- segundos totales
    por_actividad: Lista<ResumenActividad>

data ResumenActividad:
    actividadId: Id
    actividadNombre: Texto
    actividadColor: Color
    tiempo: Entero          -- segundos

-- Datos del proceso de reset (3 fases)

data OpcionActividad:
    id: Id
    nombre: Texto
    color: Color
    permanente: Booleano
    conservar: Booleano     -- checkbox en fase 2

