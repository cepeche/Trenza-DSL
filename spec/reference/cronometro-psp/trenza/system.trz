system CronometroPSP:
    initial: ModoNormal

    -- (1) Contextos base â€” mutuamente excluyentes (exactamente uno activo)
    contexts:
        ModoEdicion
        ModoNormal          -- base por defecto

    -- (2) Contextos concurrentes â€” coexisten ortogonalmente con el base
    concurrent:
        SesionActiva        -- activo cuando hay sesiÃ³n en curso

    -- (3) Contextos overlay â€” apilables, suspenden la interacciÃ³n con el base
