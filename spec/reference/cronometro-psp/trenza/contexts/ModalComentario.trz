-- contexts/ModalComentario.trz
-- Overlay: se muestra antes de iniciar una sesiÃ³n.
-- El usuario puede aÃ±adir comentario, indicar minutos retroactivos,
-- y (si hay SesionActiva) optar por sustituir la sesiÃ³n en curso.
-- Convertido de ModalComentario.trz (6 marzo 2026) a .trz (12 marzo 2026)
--
-- PROPUESTA GAP-1: este contexto necesita recibir el tipoTareaId
-- (y opcionalmente tareaId) del contexto que lo abre.
-- En app.js esto se resuelve con AppState.tareaIdPendiente â€”
-- exactamente el estado implÃ­cito que Trenza quiere eliminar.
--
-- Sintaxis propuesta para parÃ¡metros de entrada:
--   context ModalComentario:
--       input: tipoTareaId: Id, tareaId: Id?

context ModalComentario:

    -- PROPUESTA GAP-1: declarar parÃ¡metros de entrada del overlay
    -- input:
    --     tipoTareaId: Id
    --     tareaId: Id?      -- opcional: si ya se eligiÃ³ actividad

    role campo_comentario: CampoTexto
        on cambio -> actualizarComentario(self.valor)

    role campo_retroactivo: CampoNumerico
        on cambio -> actualizarRetroactivo(self.valor)

    -- Este botÃ³n siempre existe
    role boton_confirmar: Boton
        on tap -> confirmarInicio

    role boton_cancelar: Boton
        on tap -> cancelar

    -- GAP-4: Punto de extensiÃ³n para opciones dinÃ¡micas de sesiÃ³n
    slot sesion_opts

    -- PROPUESTA GAP-5: transiciÃ³n condicional basada en validaciÃ³n.
    -- confirmarInicio solo debe proceder si el estado del modal es vÃ¡lido
    -- (en este caso siempre es vÃ¡lido; no hay campo obligatorio vacÃ­o).
    -- Pero en ModalCrearTarea y ModalEditarTarea SÃ hay validaciÃ³n.

    transitions:
        on confirmarInicio -> [cerrar_overlay]   -- PROPUESTA GAP-2: cerrar overlay
                                                  -- y volver al contexto base
        on cancelar        -> [cerrar_overlay]

    effects:
        confirmarInicio -> external iniciar_sesion(tipoTareaId, comentario, retroactivo, sustituir)
        -- Nota: 'sustituir' viene del checkbox_sustituir de SesionActiva,
        -- que puede no estar presente si no hay sesiÃ³n activa.
        -- Default: sustituir = false

